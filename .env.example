# Workspace ports
SLACK_AGENT_PORT=3000
BACKEND_PORT=8001
MCP_SERVER_PORT=8000
KAFKA_PORT=9092
KAFKA_CONTROLLER_PORT=9093
KAFKA_UI_PORT=8080
POSTGRES_PORT=5432
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687

# Slack app
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_APP_TOKEN=xapp-your-app-level-token
SLACK_AGENT_DRY_RUN=true

# MCP and backend routing inside Compose
MCP_SERVER_URL=http://mcp-server:8000/mcp
BACKEND_API_URL=http://backend:8001/api/v1

# Backend auth
BACKEND_JWT_SECRET=change-me
BACKEND_JWT_ISSUER=slack-agent
JWT_SECRET=change-me
TOKEN_EXPIRY_SECONDS=3600

# Kafka
KAFKA_BROKERS=kafka:9092
KAFKA_CLIENT_ID=slack-agent
KAFKA_OUTBOUND_TOPIC_PREFIX=slack-agent
KAFKA_INBOUND_TOPIC_PREFIX=offboarding
KAFKA_CONSUMER_GROUP_ID=slack-agent-consumer
KAFKA_DLQ_TOPIC=slack-agent.dlq
KAFKA_CLUSTER_ID=braintrust-kraft-cluster

# AI
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# Slack-agent feature tuning
SOP_MONITORED_CHANNELS=
SOP_MIN_MESSAGE_LENGTH=200
SOP_KEYWORDS=deploy,pipeline,credentials,migration,workaround,config,rollback,incident
SOP_MIN_REACTIONS=3
DOSSIER_MANAGERS_CHANNEL_ID=
QUESTION_SUGGESTION_MONITORED_CHANNELS=
QUESTION_MIN_MESSAGE_LENGTH=15
QUESTION_MAX_SUGGESTIONS=3

# Backend app
APP_NAME=Slack Agent Backend
ENVIRONMENT=local
LOG_LEVEL=INFO
POSTGRES_DSN=postgresql://braintrust:braintrust@postgres:5432/braintrust

# Neo4j
NEO4J_URI=bolt://neo4j:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=braintrust

# Postgres
POSTGRES_DB=braintrust
POSTGRES_USER=braintrust
POSTGRES_PASSWORD=braintrust
DB_PASSWORD=braintrust

# Cloudflare Tunnel
CLOUDFLARE_TUNNEL_NAME=braintrust-dev
CLOUDFLARE_TUNNEL_TOKEN=your-cloudflare-tunnel-token
CLOUDFLARE_TUNNEL_HOSTNAME_API=braintrust-api.example.com
CLOUDFLARE_TUNNEL_HOSTNAME_MCP=braintrust-mcp.example.com
CLOUDFLARE_TUNNEL_HOSTNAME_KAFKA_UI=braintrust-kafka.example.com
CLOUDFLARE_TUNNEL_HOSTNAME_NEO4J=braintrust-neo4j.example.com
